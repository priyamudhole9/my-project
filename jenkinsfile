pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'git@github.com:priyamudhole9/my-project.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-app .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f my-container || true'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 80:80 --name my-container my-app'
            }
        }
    }
}
